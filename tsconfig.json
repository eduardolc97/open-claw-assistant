{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "paths": {
      "@src/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src",
    "index.ts",
    "prisma.config.ts"
  ]
}